{
  "name": "mcp-mood-quotes",
  "description": "Returns an inspirational quote based on user mood.",
  "tool": "mcp-mood-quotes",
  "endpoint": "http://localhost:8080/messages/",
  "input_spec": {
    "mood": {
      "type": "string",
      "description": "Current mood (e.g. happy, sad, tired)"
    }
  },
  "output_spec": {
    "quote": {
      "type": "string",
      "description": "A matching inspirational quote"
    }
  }
}
